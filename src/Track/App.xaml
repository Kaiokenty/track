<Application x:Class="Track.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
  <Application.Resources>
    <SolidColorBrush x:Key="BgBrush" Color="#FFF7F5F2"/>
    <SolidColorBrush x:Key="FgBrush" Color="#FF1C1917"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#FF78716C"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#FF0F766E"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#FFE7E5E4"/>
  </Application.Resources>
</Application>
