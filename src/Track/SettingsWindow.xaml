<Window x:Class="Track.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Track Settings"
        Height="520"
        Width="720"
        MinHeight="420"
        MinWidth="640"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#FF1C1917" Padding="16">
      <StackPanel>
        <TextBlock Text="Track" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>
        <Button x:Name="NavConnections" Content="Connections" Click="OnNavConnections"
                Margin="0,0,0,8" Padding="10,8" HorizontalContentAlignment="Left"
                Background="Transparent" Foreground="White" BorderThickness="0"/>
        <Button x:Name="NavGeneral" Content="General" Click="OnNavGeneral"
                Margin="0,0,0,8" Padding="10,8" HorizontalContentAlignment="Left"
                Background="Transparent" Foreground="#FFA8A29E" BorderThickness="0"/>
        <TextBlock Text="Alerts &amp; budgets in Phase 2"
                   Foreground="#FF78716C" FontSize="11" Margin="4,16,0,0" TextWrapping="Wrap"/>
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Column="1" Padding="24" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <TextBlock x:Name="SectionTitle" Text="Connections" FontSize="22" FontWeight="SemiBold"
                   Foreground="{StaticResource FgBrush}" Margin="0,0,0,8"/>
        <TextBlock Text="Link Cursor via local session (subscription). API keys for cost tracking come in Phase 2."
                   Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>

        <StackPanel x:Name="ConnectionsPanel"/>
        <StackPanel x:Name="GeneralPanel" Visibility="Collapsed">
          <CheckBox x:Name="LaunchAtStartup" Content="Launch Track with Windows"
                    Margin="0,0,0,12" IsEnabled="False"
                    ToolTip="Wire up in Phase 1"/>
          <TextBlock Text="Poll interval" FontWeight="SemiBold" Margin="0,0,0,6"/>
          <ComboBox Width="200" HorizontalAlignment="Left" SelectedIndex="1" IsEnabled="False">
            <ComboBoxItem Content="1 minute"/>
            <ComboBoxItem Content="5 minutes"/>
            <ComboBoxItem Content="15 minutes"/>
          </ComboBox>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
