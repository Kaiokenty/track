<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\Track.Core\Track.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="H.NotifyIcon.Wpf" Version="2.3.2" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>Assets\track.ico</ApplicationIcon>
    <RootNamespace>Track</RootNamespace>
    <AssemblyName>Track</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <Resource Include="Assets\track.ico" />
  </ItemGroup>

</Project>
